---
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/data/site";
import { orderedTools } from "@/data/tools";
import ToolLayout from "@/layouts/ToolLayout.astro";

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${site.name} Home`,
  url: site.url,
  description: site.description,
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: site.url
  }
};
---

<ToolLayout
  title="Landlord Math Toolkit | Rental Calculators for Lease Math"
  description={site.description}
>
  <Fragment slot="head">
    <JsonLd data={webSiteSchema} />
    <JsonLd data={collectionPageSchema} />
  </Fragment>
  <section class="hero-card homepage-hero">
    <div>
      <p class="eyebrow">Rental calculators for everyday lease math</p>
      <h1>Landlord Math, without spreadsheet friction.</h1>
      <p class="hero-copy">
        Landlord Math Toolkit is a small set of worksheet-style calculators for the rent questions that come up
        every month: prorations, move-in totals, rent increases, and late fees.
      </p>
      <p class="hero-note">
        Each tool keeps the formulas visible, adds a copy-ready summary, and includes plain-language notes so
        the output is useful in real lease conversations.
      </p>
    </div>

    <div class="common-tasks-card">
      <div class="section-heading compact-heading">
        <h2>Common Landlord Calculations</h2>
      </div>
      <div class="task-grid">
        <a class="task-link" href="/prorated-rent-calculator">
          <strong>Calculate partial-month rent</strong>
          <span>Estimate what a tenant should pay for a mid-month move-in or move-out.</span>
        </a>
        <a class="task-link" href="/move-in-cost-calculator">
          <strong>Estimate move-in cash due</strong>
          <span>Bundle rent, deposit, prorated rent, and fees into one practical total.</span>
        </a>
        <a class="task-link" href="/rent-increase-calculator">
          <strong>Compare a rent increase</strong>
          <span>See the updated monthly rent in dollars and percent before sending notice.</span>
        </a>
        <a class="task-link" href="/late-fee-calculator">
          <strong>Estimate late fees</strong>
          <span>Check what a late charge could add to unpaid rent under your lease terms.</span>
        </a>
      </div>
    </div>
  </section>

  <section class="detail-card trust-strip">
    <p>Formulas are shown on every calculator.</p>
    <p>Each tool includes assumptions and plain-language notes.</p>
  </section>

  <section class="detail-card">
    <h2>Calculator Tools</h2>
    <div class="tool-grid">
      {orderedTools.map((tool) => (
        <a class="tool-link" href={`/${tool.slug}`}>
          <strong>{tool.name}</strong>
          <p>{tool.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="detail-grid">
    <article class="detail-card">
      <h2>What this site is for</h2>
      <p>
        This site is built for small landlords, property managers, and anyone who needs quick rent math without
        digging through a spreadsheet.
      </p>
      <ul>
        <li>Calculator-first pages with short, useful supporting content</li>
        <li>Clear assumptions and methodology on every tool</li>
        <li>Copyable summaries for texts, emails, and rent ledgers</li>
      </ul>
    </article>

    <article class="detail-card">
      <h2>What this site is not</h2>
      <p>
        This site stays focused on quick rent math. It does not try to replace lease review, compliance checks,
        or full property management software.
      </p>
      <ul>
        <li>No tenant portals or saved accounts</li>
        <li>No city-level rent comps or state-by-state legal rule engine</li>
        <li>No payment processing or document storage</li>
      </ul>
    </article>
  </section>
</ToolLayout>
