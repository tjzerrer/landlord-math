---
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/data/site";
import ToolLayout from "@/layouts/ToolLayout.astro";

const pageUrl = `${site.url}/about/`;
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "About",
  url: pageUrl,
  description: "Why Landlord Math Toolkit exists and how the calculators are designed.",
  isPartOf: {
    "@type": "WebSite",
    name: site.name,
    url: site.url
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: site.name, item: site.url },
    { "@type": "ListItem", position: 2, name: "About", item: pageUrl }
  ]
};
---

<ToolLayout
  title="About | Landlord Math Toolkit"
  description="Why Landlord Math Toolkit exists and how the calculators are designed."
>
  <Fragment slot="head">
    <JsonLd data={webPageSchema} />
    <JsonLd data={breadcrumbSchema} />
  </Fragment>
  <section class="hero-card">
    <p class="eyebrow">About</p>
    <h1>Focused tools for common landlord calculations.</h1>
    <p class="hero-copy">
      Landlord Math Toolkit is designed around a simple idea: the fastest tool is often the most useful one.
    </p>
  </section>

  <section class="detail-grid">
    <article class="detail-card">
      <h2>Why this site exists</h2>
      <p>
        Real lease math is often simple in theory but messy in practice. Partial months, fees, and summary
        messages create friction that this site is meant to remove.
      </p>
    </article>

    <article class="detail-card">
      <h2>How the tools are built</h2>
      <p>
        Every calculator is designed to show the result, explain the formula, and make it easy to move that
        number into an email, text, or lease summary.
      </p>
    </article>
  </section>
</ToolLayout>
