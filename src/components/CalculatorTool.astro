---
import { tools } from "@/data/tools";
import type { ToolConfig, ToolField, ToolSlug } from "@/lib/types";

interface Props {
  tool: ToolConfig;
}

const { tool } = Astro.props;

const relatedTools = tool.relatedTools.map((slug: ToolSlug) => tools[slug]);
const nextSteps: Record<
  ToolSlug,
  { title: string; links: Array<{ slug: ToolSlug; label: string; description: string }> }
> = {
  "prorated-rent-calculator": {
    title: "Next step",
    links: [
      {
        slug: "move-in-cost-calculator",
        label: "Estimate move-in cash due",
        description: "Roll prorated rent into the total a tenant should bring at move-in."
      }
    ]
  },
  "move-in-cost-calculator": {
    title: "Related landlord calculation",
    links: [
      {
        slug: "prorated-rent-calculator",
        label: "Calculate partial-month rent",
        description: "Use this first if the lease starts or ends mid-month."
      },
      {
        slug: "late-fee-calculator",
        label: "Estimate late fees",
        description: "Check what could be added if the move-in balance is paid late."
      }
    ]
  },
  "rent-increase-calculator": {
    title: "Related landlord calculation",
    links: [
      {
        slug: "late-fee-calculator",
        label: "Estimate late fees",
        description: "Useful if you also need to model balances that stay unpaid after the increase."
      },
      {
        slug: "prorated-rent-calculator",
        label: "Calculate partial-month rent",
        description: "Helpful when a revised rent needs to be applied for only part of a month."
      }
    ]
  },
  "late-fee-calculator": {
    title: "Related landlord calculation",
    links: [
      {
        slug: "rent-increase-calculator",
        label: "Compare a rent increase",
        description: "Check the new monthly rent before applying any future late-fee rules."
      },
      {
        slug: "move-in-cost-calculator",
        label: "Estimate move-in cash due",
        description: "Useful when you want the full upfront balance in one tenant-ready summary."
      }
    ]
  }
};
const workflow = nextSteps[tool.slug];

function getInputMode(field: ToolField) {
  if (field.type === "currency" || field.type === "number") {
    return "decimal";
  }

  return undefined;
}

function getInputType(field: ToolField) {
  if (field.type === "currency" || field.type === "number") {
    return "number";
  }

  return field.type;
}
---

<section class="hero-card">
  <p class="eyebrow">Landlord math toolkit</p>
  <h1>{tool.name}</h1>
  <p class="hero-copy">{tool.intro}</p>
  <p class="hero-note">
    Built for quick lease math with visible assumptions, plain-English output, and copy-ready summaries.
  </p>
</section>

<section
  class="calculator-shell"
  data-calculator-root
  data-tool={tool.slug}
  data-tool-name={tool.name}
  data-tool-config={JSON.stringify(tool)}
>
  <div class="calculator-main">
    <form class="tool-form" data-calculator-form>
      {tool.sections.map((section) => (
        <fieldset class="form-section">
          <legend>{section.title}</legend>
          <p>{section.description}</p>
          <div class="field-grid">
            {section.fields.map((field) => (
              <label class="field">
                <span>{field.label}</span>
                {field.type === "select" ? (
                  <select name={field.name} required={field.required}>
                    {field.options.map((option) => (
                      <option value={option.value}>{option.label}</option>
                    ))}
                  </select>
                ) : (
                  <input
                    name={field.name}
                    type={getInputType(field)}
                    inputmode={getInputMode(field)}
                    min={field.min}
                    step={field.step}
                    placeholder={field.placeholder}
                    required={field.required}
                  />
                )}
                {field.help && <small>{field.help}</small>}
              </label>
            ))}
          </div>
        </fieldset>
      ))}

      <div class="form-actions">
        <button type="submit" class="primary-button">Calculate</button>
        <button type="reset" class="secondary-button">Reset</button>
      </div>
      <p class="form-error" data-form-error hidden></p>
    </form>

    <aside class="result-card" data-result-card>
      <div class="result-card__header">
        <p class="result-label">Output summary</p>
        <div class="result-actions">
          <button type="button" class="copy-button" data-copy-summary disabled>Copy summary</button>
          <button type="button" class="copy-button" data-print-summary hidden>Print / Save PDF</button>
        </div>
      </div>
      <p class="result-empty">Enter your numbers and calculate to see the result.</p>
      <div class="result-content" data-result-content hidden>
        <p class="result-sentence" data-result-sentence></p>
        <dl class="result-breakdown" data-result-breakdown></dl>
        <p class="summary-note" data-summary-note></p>
      </div>

      <div class="workflow-card">
        <p class="workflow-label">{workflow.title}</p>
        <div class="workflow-links">
          {workflow.links.map((item) => (
            <a class="workflow-link" href={`/${item.slug}`}>
              <strong>{item.label}</strong>
              <span>{item.description}</span>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-card">
    <div class="section-heading">
      <h2>How We Calculated This</h2>
      <a class="text-link" href="/methodology">See full methodology</a>
    </div>
    <ol>
      {tool.methodology.map((item) => (
        <li>{item}</li>
      ))}
    </ol>
  </article>

  <article class="detail-card">
    <h2>{tool.example.title}</h2>
    <p>{tool.example.summary}</p>
    <ol>
      {tool.example.steps.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </article>
</section>

<section class="detail-grid">
  <article class="detail-card trust-card">
    <div class="section-heading">
      <h2>Assumptions</h2>
      <p>Last updated {tool.lastUpdated}</p>
    </div>
    <ul>
      {tool.assumptions.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <p class="disclaimer">This tool is for informational use only and is not legal, tax, or financial advice.</p>
    <p class="methodology-link-row">
      <a class="text-link" href="/methodology">See full methodology</a>
    </p>
  </article>

  <article class="detail-card">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      {tool.faqs.map((faq) => (
        <details>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </article>
</section>

<section class="detail-card related-card">
  <h2>Related Tools</h2>
  <div class="related-grid">
    {relatedTools.map((item) => (
      <a class="related-link" href={`/${item.slug}`}>
        <strong>{item.shortName}</strong>
        <span>{item.description}</span>
      </a>
    ))}
  </div>
</section>

<script>
  import "@/scripts/calculator-tool";
</script>
